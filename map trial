<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Security-Policy" content="default-src * 'unsafe-inline' 'unsafe-eval' data: blob:;">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.markercluster/1.5.3/MarkerCluster.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.markercluster/1.5.3/MarkerCluster.Default.css"/>
  <style>
    body { margin: 0; }
    #map { width: 100vw; height: 100vh; }
  </style>
</head>
<body>
  <div id="map"></div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.markercluster/1.5.3/leaflet.markercluster.min.js"></script>

  <script>
    const params = new URLSearchParams(window.location.search);
    const lat = parseFloat((params.get("lat") || "").replace(",", ".")) || 51.18;
    const lon = parseFloat((params.get("lon") || "").replace(",", ".")) || 71.44;

    const map = L.map("map").setView([lat, lon], 13);

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(map);

    const myIcon = L.divIcon({
      html: '📍',
      iconSize: [30, 30],
      className: ''
    });

    if (params.get("lat")) {
      L.marker([lat, lon], { icon: myIcon })
        .addTo(map)
        .bindPopup("Я здесь")
        .openPopup();
    }

    const clusters = L.markerClusterGroup();

    fetch("https://ahcarina711.github.io/map/points.json", { mode: "cors" })
      .then(r => r.json())
      .then(data => {
        data.forEach(point => {
          const pointLat = parseFloat(String(point["Широта"]).replace(",", "."));
          const pointLon = parseFloat(String(point["Долгота"]).replace(",", "."));

          if (!isNaN(pointLat) && !isNaN(pointLon)) {
            const source = point["Source"];

            let color = "gray";
            if (source === "Coverage") color = "blue";
            if (source === "OutOfCoverage") color = "red";

            const marker = L.circleMarker([pointLat, pointLon], {
              radius: 7,
              fillColor: color,
              color: color,
              weight: 1,
              opacity: 1,
              fillOpacity: 0.85
            });

            marker
              .bindPopup(
                "<b>" + (point["SO"] || "") + "</b><br>" +
                "Код ТТ: " + (point["Код ТТ"] || "") + "<br>" +
                "Адрес: " + (point["Адрес"] || "") + "<br>" +
                "Source: " + (point["Source"] || "")
              )
              .bindTooltip(point["SO"] || "Без названия", {
                direction: "top",
                offset: [0, -8],
                opacity: 0.9
              });

            clusters.addLayer(marker);
          }
        });

        map.addLayer(clusters);
      })
      .catch(err => console.error("Ошибка загрузки точек:", err));
  </script>
</body>
</html>
